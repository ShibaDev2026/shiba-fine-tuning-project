# docker-compose 環境變數範本
# 用法：cp .env.example .env，填入真值後 docker compose up
# 注意：.env 在 .gitignore，切勿提交含真實 key 的檔案

# ─── Teacher API Keys ──────────────────────────────────────────
# 命名規則：SHIBA_TEACHER_KEY_<keychain_ref 大寫、非英數轉底線>
# 僅 docker / Linux 執行時需要；host (macOS) 優先讀 Keychain
# 對應 teachers 表 keychain_ref 欄位，可用下列 SQL 查詢：
#   sqlite3 ./data/shiba-brain.db "SELECT name, keychain_ref FROM teachers;"

SHIBA_TEACHER_KEY_GEMINI_API_KEY=
# SHIBA_TEACHER_KEY_GROK_API_KEY=
# SHIBA_TEACHER_KEY_GITHUB_API_KEY=
# SHIBA_TEACHER_KEY_MISTRAL_API_KEY=

# ─── Runtime 覆寫（可選）──────────────────────────────────────
# docker-compose 會自動設 SHIBA_RUNTIME=docker，通常不需覆寫
# SHIBA_RUNTIME=docker
